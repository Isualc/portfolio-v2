---
interface Props { lang?: "de" | "en"; }
const { lang = "de" } = Astro.props;

const t = {
  de: {
    kicker: "Über mich",
    headA: "Pflege verstehen.",
    headB: "Software bauen.",
    role1: "Entwickler",
    name1: "Claus Hierzer",
    p1a: `Pflegehelfer mit Auszeichnung, 2005. Fünfzehn Jahre in Pflegeeinrichtungen, acht davon in der Demenzpflege. Die Laufbahn endete mit einem Bandscheibenvorfall — nicht mit der Berufung. Was ich in diesen Jahren am Bett gelernt habe, steckt heute in jedem Prompt, in jeder Regel und in jedem „Nein" zu einem Feature.`,
    p1b: "Seit Juli 2024 Softwareentwickler, Umstieg über CodersBay Kapfenberg. Die Lehrabschlussprüfung habe ich bewusst verschoben, um den Aufbau von Isualc AI Solutions vollständig zu stemmen. Was hier entsteht, ist kein generisches KI-Tooling — jede Funktion hat ein konkretes Vorbild aus der Praxis, entweder aus meinem eigenen Alltag oder dem von jemandem, mit dem ich gearbeitet habe.",
    list1: [
      "15 Jahre Pflege · 8 Jahre Demenzpflege",
      "Flutter · Dart · Python · Android · Windows",
      "Offline-AI mit Gemma 4 E2B, llama.cpp, MediaPipe",
    ],
    role2: "Arbeitsrahmen",
    name2: "Isualc AI Solutions",
    p2: "Arbeitstitel für den Rahmen, unter dem ich KIPP und die verwandten Werkzeuge weiterentwickle. Sitz in der Steiermark, Gründung im Sommer 2026 geplant.",
  },
  en: {
    kicker: "About me",
    headA: "Understand care.",
    headB: "Build software.",
    role1: "Developer",
    name1: "Claus Hierzer",
    p1a: `Certified nursing assistant since 2005. Fifteen years in care facilities, eight of them in dementia care. The career ended with a herniated disc — not with the vocation. What I learned in those years at the bedside now sits in every prompt, every rule, and every „no" to a feature.`,
    p1b: "Software engineer since July 2024, starting at CodersBay Kapfenberg. I've deliberately postponed the final apprenticeship exam to fully carry the build-up of Isualc AI Solutions. What you see here isn't generic AI tooling — every feature has a concrete precedent from practice, either from my own daily life or from someone I've worked with.",
    list1: [
      "15 years of caregiving · 8 years in dementia care",
      "Flutter · Dart · Python · Android · Windows",
      "Offline AI with Gemma 4 E2B, llama.cpp, MediaPipe",
    ],
    role2: "Working frame",
    name2: "Isualc AI Solutions",
    p2: "Working title for the frame under which I continue to develop KIPP and related tools. Based in Styria, founding planned for summer 2026.",
  },
}[lang];
---

<section class="section" id="ueber" aria-labelledby="about-head">
  <div class="container">
    <div class="section-head">
      <p class="k">{t.kicker}</p>
      <h2 id="about-head">{t.headA} <em>{t.headB}</em></h2>
    </div>

    <div class="about-grid">
      <article class="about-card primary">
        <div class="portrait" aria-hidden="true"></div>
        <div class="role">{t.role1}</div>
        <h3>{t.name1}</h3>
        <p>{t.p1a}</p>
        <p>{t.p1b}</p>
        <ul>
          {t.list1.map(item => <li>{item}</li>)}
        </ul>
      </article>

      <aside class="about-card" style="align-self: start;">
        <div class="role">{t.role2}</div>
        <h3>{t.name2}</h3>
        <p style="font-size: .94rem;">{t.p2}</p>
      </aside>
    </div>
  </div>
</section>
