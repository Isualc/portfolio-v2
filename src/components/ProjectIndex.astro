---
import { getCollection } from "astro:content";

interface Props { lang?: "de" | "en"; }
const { lang = "de" } = Astro.props;

const all = await getCollection("projects");
const projects = all.sort((a, b) => a.data.order - b.data.order);

const t = {
  de: {
    kicker: "Portfolio",
    headA: "Sechs Arbeiten an der Schnittstelle von",
    headB: "Pflege und Software.",
    sub: "Jedes Projekt beantwortet eine konkrete Frage aus dem Praxisbetrieb — Demenzbegleitung, Förderanträge, Bewerbungsprozesse, Agent-Architektur. Gebaut, nicht gedacht.",
    action: "Details",
  },
  en: {
    kicker: "Portfolio",
    headA: "Six works where",
    headB: "care meets software.",
    sub: "Each project answers a specific question from working practice — dementia companionship, funding applications, job-application flow, agent architecture. Built, not hypothesised.",
    action: "Details",
  },
}[lang];
---

<section class="section" id="projekte" aria-labelledby="proj-head">
  <div class="container">
    <div class="section-head">
      <p class="k">{t.kicker}</p>
      <h2 id="proj-head">{t.headA} <em>{t.headB}</em></h2>
      <p class="sub">{t.sub}</p>
    </div>

    <div class="proj-index" role="list">
      {projects.map(p => (
        <a class="proj-row" href={`/projekte/${p.id}`} role="listitem">
          <span class="proj-num">/ {p.data.num}</span>
          <div class="proj-name" set:html={p.data.titleHtml || p.data.title}></div>
          <p class="proj-desc">{p.data.description}</p>
          <span class="proj-action">{t.action} <span class="arrow">→</span></span>
        </a>
      ))}
    </div>
  </div>
</section>
